                                                        Binding="{Binding BiDaily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridCheckBoxColumn Width="48" IsReadOnly="True" Binding="{Binding Implants}">
                                    <DataGridCheckBoxColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Contain&#x0a;implant" TextAlignment="Center" TextWrapping="Wrap" FontSize="9"/>
                                        </DataTemplate>
                                    </DataGridCheckBoxColumn.HeaderTemplate>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn IsReadOnly="True" Width="40" Binding="{Binding LoadQty}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Qty of items&#x0a;in the load" TextAlignment="Center" TextWrapping="Wrap" FontSize="9"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn IsReadOnly="True" Width="78" Binding="{Binding ExposureTimeTempDisplay}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Exposure time&#x0a;/ Temp" TextAlignment="Center" TextWrapping="Wrap" FontSize="9"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="62" MinWidth="58">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Incubator temp&#x0a;(e.g. 60°C +12)" TextAlignment="Center" TextWrapping="Wrap" FontSize="8"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding BiIncubatorChecked}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      ToolTipService.ToolTip="Incubator checked"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding BiIncubatorChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      ToolTipService.ToolTip="Incubator checked"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="BiLogTimeInMergedColumn" Width="150" MinWidth="140">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Time In / Initials" FontWeight="SemiBold" FontSize="9" TextAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="HH:mm · initials" FontSize="8" TextAlignment="Center" Opacity="0.82" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource BiLogTimeInitialsCellBorder}" VerticalAlignment="Stretch" Margin="2,4"
                                                    ToolTipService.ToolTip="Time uses the cycle date (deployment zone). Staff initials on removal.">
                                                <Grid VerticalAlignment="Center" MinHeight="28">
                                                    <TextBlock Grid.Column="0"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Stretch"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding BiTimeInDisplayTime}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding BiTimeInTimeText}" Value="">
                                                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource BiLogTimeInitialsCellBorder}" VerticalAlignment="Stretch" Margin="2,4"
                                                    KeyboardNavigation.TabNavigation="Continue">
                                                <Grid VerticalAlignment="Stretch" MinHeight="28">
                                                    <bi:BiMasked24hTimeTextBox Grid.Column="0"
                                                                               Style="{StaticResource BiLogMaskedTimeChrome}"
                                                                               ValueHm="{Binding BiTimeInTimeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                               IsTimeOut="False"
                                                                               MouseEnter="BiLogTimeTextBox_OnMouseEnter"
                                                                               GotKeyboardFocus="BiLogTimeTextBox_OnGotKeyboardFocus"
                                                                               ToolTipService.ToolTip="Digits only (e.g. 1830→18:30). Enter → next row."/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="BiLogTimeOutMergedColumn" Width="170" MinWidth="160">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Time Out / Initials" FontWeight="SemiBold" FontSize="9" TextAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="HH:mm · initials" FontSize="8" TextAlignment="Center" Opacity="0.82" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource BiLogTimeInitialsCellBorder}" VerticalAlignment="Stretch" Margin="2,2"
                                                    ToolTipService.ToolTip="Time out uses the cycle date (deployment zone).">
                                                <Grid VerticalAlignment="Center" MinHeight="28">
                                                    <TextBlock Grid.Column="0"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Stretch"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding BiTimeOutDisplayTime}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding BiTimeOutTimeText}" Value="">
                                                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource BiLogTimeInitialsCellBorder}" VerticalAlignment="Stretch" Margin="2,2"
                                                    KeyboardNavigation.TabNavigation="Continue">
                                                <Grid VerticalAlignment="Stretch" MinHeight="28">
                                                    <bi:BiMasked24hTimeTextBox Grid.Column="0"
                                                                               Style="{StaticResource BiLogMaskedTimeChrome}"
                                                                               VerticalAlignment="Stretch"
                                                                               MinHeight="32" Height="32"
                                                                               ValueHm="{Binding BiTimeOutTimeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                               IsTimeOut="True"
                                                                               TabIndex="0"
                                                                               MouseEnter="BiLogTimeTextBox_OnMouseEnter"
                                                                               GotKeyboardFocus="BiLogTimeTextBox_OnGotKeyboardFocus"
                                                                               ToolTipService.ToolTip="Digits only. Enter → next row."/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="BiLogProc24MinColumn" Header="" Width="56" MinWidth="52">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="BI processed" FontWeight="SemiBold" FontSize="8" TextAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="24 MIN" FontSize="8" TextAlignment="Center" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BiProcessed24mDisplay}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="18" FontWeight="ExtraBold"
                                                       Foreground="#0B1220"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <bi:BiPlusMinusSignToggle VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                     Sign="{Binding BiProcessedResult24m, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="BiLogProc24HrColumn" Header="" Width="56" MinWidth="52">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="BI processed" FontWeight="SemiBold" FontSize="8" TextAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="24 HRS" FontSize="8" TextAlignment="Center" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BiProcessed24hDisplay}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="18" FontWeight="ExtraBold"
                                                       Foreground="#0B1220"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <bi:BiPlusMinusSignToggle VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                     Sign="{Binding BiProcessedResult24h, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="BiLogCtrl24MinColumn" Header="" Width="56" MinWidth="52">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="BI control" FontWeight="SemiBold" FontSize="8" TextAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="24 MIN" FontSize="8" TextAlignment="Center" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BiControl24mDisplay}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="18" FontWeight="ExtraBold"
                                                       Foreground="#0B1220"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <bi:BiPlusMinusSignToggle VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                     Sign="{Binding BiControlResult24m, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="BiLogCtrl24HrColumn" Header="" Width="56" MinWidth="52">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="BI control" FontWeight="SemiBold" FontSize="8" TextAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="24 HRS" FontSize="8" TextAlignment="Center" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BiControl24hDisplay}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="18" FontWeight="ExtraBold"
                                                       Foreground="#0B1220"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <bi:BiPlusMinusSignToggle VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                     Sign="{Binding BiControlResult24h, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Operator" IsReadOnly="True" Width="58" Binding="{Binding OperatorName}"/>
                                <DataGridTextColumn Width="180" MinWidth="160"
                                                    Binding="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Comments /&#x0a;result" TextAlignment="Center" TextWrapping="Wrap" FontSize="9"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Analytics view -->
                        <Grid Name="AnalyticsView" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F8FAFD" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="From (local)"/>
                                    <DatePicker Name="AnalyticsFromDate" SelectedDateFormat="Short" Width="140"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="To (local)"/>
                                    <DatePicker Name="AnalyticsToDate" SelectedDateFormat="Short" Width="140"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Name="AnalyticsScopePanel" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="Scope"/>
                                    <ComboBox Name="AnalyticsScopeCombo" Width="170" IsEditable="False">
                                        <ComboBoxItem Content="Overall (all users)" IsSelected="True"/>
                                        <ComboBoxItem Content="Individual user"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="6" Name="AnalyticsUserPanel" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="User"/>
                                    <ComboBox Name="AnalyticsUserCombo" Width="220" IsEditable="False"/>
                                </StackPanel>
                                <StackPanel Grid.Column="8" Name="AnalyticsPresetPanel" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <ComboBox Name="AnalyticsPresetsCombo" Width="220" IsEditable="False" Margin="0,0,8,0"/>
                                    <Button Name="AnalyticsPresetSaveButton" Content="Save" Style="{StaticResource SecondaryToolbarButton}" MinWidth="72" Margin="0,0,8,0"/>
                                    <Button Name="AnalyticsPresetRenameButton" Content="Rename" Style="{StaticResource SecondaryToolbarButton}" MinWidth="80" Margin="0,0,8,0"/>
                                    <Button Name="AnalyticsPresetDeleteButton" Content="Delete" Style="{StaticResource SecondaryToolbarButton}" MinWidth="80" Margin="0,0,8,0"/>
                                    <Button Name="AnalyticsPresetSetDefaultButton" Content="Set default" Style="{StaticResource SecondaryToolbarButton}" MinWidth="100"/>
                                </StackPanel>
                                <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="3" Margin="0,0,10,0"
                                            VerticalAlignment="Bottom">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="View" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="6,0,8,0"/>
                                            <ToggleButton Name="AnalyticsPlainTextToggle"
                                                          Content="Report"
                                                          Style="{StaticResource AnalyticsReportToggle}"
                                                          MinWidth="76"
                                                          ToolTip="Switch between dashboard charts and a compact report view."/>
                                        </StackPanel>
                                    </Border>
                                    <Button Name="AnalyticsExportCsvButton" Content="Export CSV" Style="{StaticResource SecondaryToolbarButton}" MinWidth="100" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                    <Button Name="AnalyticsExportXlsxButton" Content="Export XLSX" Style="{StaticResource SecondaryToolbarButton}" MinWidth="110" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                    <Button Name="AnalyticsExportPdfButton" Content="Export PDF" Style="{StaticResource SecondaryToolbarButton}" MinWidth="100" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                    <Button Name="AnalyticsPrintButton" Content="Print" Style="{StaticResource SecondaryToolbarButton}" MinWidth="90" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                </StackPanel>
                                <Button Grid.Column="12" Name="AnalyticsRefreshButton" Content="Refresh" Style="{StaticResource PrimaryButton}" MinWidth="110" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="Sterilizer"/>
                                    <ComboBox Name="AnalyticsFilterSterilizerCombo" Width="180" IsEditable="False"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="Status"/>
                                    <ComboBox Name="AnalyticsFilterStatusCombo" Width="150" IsEditable="False"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="Implants"/>
                                    <ComboBox Name="AnalyticsFilterImplantsCombo" Width="120" IsEditable="False"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="BI Result"/>
                                    <ComboBox Name="AnalyticsFilterBiResultCombo" Width="140" IsEditable="False"/>
                                </StackPanel>
                                <StackPanel Grid.Column="8">
                                    <TextBlock Style="{StaticResource CaptionLabel}" Text="Search"/>
                                    <TextBox Name="AnalyticsFilterSearchTextBox" MinWidth="220"/>
                                </StackPanel>
                                <StackPanel Grid.Column="9" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Name="AnalyticsFiltersResetButton" Content="Reset filters" Style="{StaticResource SecondaryToolbarButton}" MinWidth="110" Margin="0,0,8,0"/>
                                    <Button Name="AnalyticsFiltersApplyButton" Content="Apply" Style="{StaticResource PrimaryButton}" MinWidth="90"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Plain text statistics -->
                        <Border Grid.Row="4" Name="AnalyticsPlainTextPanel" Padding="0,8,0,0" Visibility="Collapsed">
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="18">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Statistics report" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Name="AnalyticsPlainRange" Margin="0,4,0,0" FontSize="12" Foreground="#64748B" Text="—"/>
                                    <TextBlock Name="AnalyticsPlainSupplement" Margin="0,10,0,0" FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Text=""/>
                                    <Border Margin="0,12,0,0" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="BI log sheet (periodic QA — paper form fields on loads)" FontSize="12" FontWeight="SemiBold" Foreground="#9A3412"/>
                                            <TextBlock Name="AnalyticsPlainBiPaperDetailText" Margin="0,4,0,0" FontSize="11" Foreground="#C2410C" TextWrapping="Wrap" Text="—"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,12,0,0" Height="1" Background="#EEF2F7"/>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Key totals -->
                                        <Border Grid.Column="0" Grid.Row="0" Background="#F8FAFD" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Key totals" FontWeight="SemiBold" Foreground="#111827" FontSize="13"/>
                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Total loads" Foreground="#64748B" FontSize="11"/>
                                                        <TextBlock Name="AnalyticsPlainTotalLoads" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Text="0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Total pcs / qty" Foreground="#64748B" FontSize="11"/>
                                                        <TextBlock Name="AnalyticsPlainPcsQty" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Text="0 / 0"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Completed" Foreground="#64748B" FontSize="11"/>
                                                        <TextBlock Name="AnalyticsPlainCompleted" FontSize="16" FontWeight="SemiBold" Foreground="#10B981" Text="0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Draft" Foreground="#64748B" FontSize="11"/>
                                                        <TextBlock Name="AnalyticsPlainDraft" FontSize="16" FontWeight="SemiBold" Foreground="#F59E0B" Text="0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Voided" Foreground="#64748B" FontSize="11"/>
                                                        <TextBlock Name="AnalyticsPlainVoided" FontSize="16" FontWeight="SemiBold" Foreground="#EF4444" Text="0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Top operators -->
                                        <Border Grid.Column="2" Grid.Row="0" Background="#F8FAFD" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Top operators" FontWeight="SemiBold" Foreground="#111827" FontSize="13"/>
                                                <DataGrid Name="AnalyticsPlainTopOperatorsGrid" Margin="0,10,0,0"
                                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                                          IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                          AlternationCount="2" RowHeight="28"
                                                          BorderBrush="#DCE4EE" BorderThickness="1" Background="White">
                                                    <DataGrid.RowStyle>
                                                        <Style TargetType="DataGridRow">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="AlternationIndex" Value="1">
                                                                    <Setter Property="Background" Value="#FBFDFF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGrid.RowStyle>
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40" IsReadOnly="True"/>
                                                        <DataGridTextColumn Header="Operator" Binding="{Binding Name}" Width="2*"/>
                                                        <DataGridTextColumn Header="Loads" Binding="{Binding Loads}" Width="*" IsReadOnly="True"/>
                                                        <DataGridTextColumn Header="Pcs" Binding="{Binding Pcs}" Width="*" IsReadOnly="True"/>
                                                        <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="*" IsReadOnly="True"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Top sterilizers -->
                                        <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="3" Background="#F8FAFD" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Top sterilizers" FontWeight="SemiBold" Foreground="#111827" FontSize="13"/>
                                                <DataGrid Name="AnalyticsPlainTopSterilizersGrid" Margin="0,10,0,0"
                                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                                          IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                          AlternationCount="2" RowHeight="28"
                                                          BorderBrush="#DCE4EE" BorderThickness="1" Background="White">
                                                    <DataGrid.RowStyle>
                                                        <Style TargetType="DataGridRow">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="AlternationIndex" Value="1">
                                                                    <Setter Property="Background" Value="#FBFDFF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGrid.RowStyle>
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40" IsReadOnly="True"/>
                                                        <DataGridTextColumn Header="Sterilizer" Binding="{Binding Name}" Width="2*"/>
                                                        <DataGridTextColumn Header="Loads" Binding="{Binding Loads}" Width="*" IsReadOnly="True"/>
                                                        <DataGridTextColumn Header="Pcs" Binding="{Binding Pcs}" Width="*" IsReadOnly="True"/>
                                                        <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="*" IsReadOnly="True"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,14,0,0" Background="#F8FAFD" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Breakdown" FontWeight="SemiBold" Foreground="#111827" FontSize="13"/>
                                            <TextBlock Text="Double-click a row to open a drill-down window filtered by this breakdown." FontSize="10" Foreground="#6B7280" Margin="0,2,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="View" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#374151"/>
                                                <ComboBox Name="AnalyticsPlainBreakdownCombo" Width="260" IsEditable="False" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <DataGrid Name="AnalyticsPlainBreakdownGrid" Height="220" AutoGenerateColumns="False"
                                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                      SelectionMode="Single" IsReadOnly="True"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Dashboard layout -->
                        <Border Grid.Row="6" Name="AnalyticsDashboardPanel" Padding="0,8,0,0" HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="Analytics Dashboard" FontSize="18" FontWeight="SemiBold" Foreground="#111827"/>
                                <TextBlock Name="AnalyticsHeaderRangeText" Margin="0,2,0,0" FontSize="11" Foreground="#6B7280" Text="—"/>
                                <TextBlock Name="AnalyticsCompareText" Margin="0,6,0,0" FontSize="11" Foreground="#475569" TextWrapping="Wrap" Text=""/>
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="QA tests (in range)" FontSize="12" FontWeight="SemiBold" Foreground="#14532D"/>
                                        <TextBlock Name="AnalyticsQaSummaryText" Margin="0,4,0,0" FontSize="11" Foreground="#166534" TextWrapping="Wrap" Text="—"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="Instrument checks (in range)" FontSize="12" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                        <TextBlock Name="AnalyticsInstrumentSummaryText" Margin="0,4,0,0" FontSize="11" Foreground="#1D4ED8" TextWrapping="Wrap" Text="—"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Margin="0,12,0,0" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="BI log sheet (periodic QA — paper form fields on loads)" FontSize="12" FontWeight="SemiBold" Foreground="#9A3412"/>
                                    <TextBlock Name="AnalyticsBiPaperDetailText" Margin="0,4,0,0" FontSize="11" Foreground="#C2410C" TextWrapping="Wrap" Text="—"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Margin="0,12,0,0" Background="#F8FAFD" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="BI log analytics (structured)" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Name="AnalyticsBiLogSummaryText" Margin="0,4,0,0" FontSize="11" Foreground="#334155" TextWrapping="Wrap" Text="—"/>
                                </StackPanel>
                            </Border>

                            <!-- KPI cards -->
                            <UniformGrid Margin="0,10,0,0" Columns="6" HorizontalAlignment="Stretch">
                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Loads" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                        <TextBlock Name="AnalyticsTotalText" FontSize="18" FontWeight="SemiBold" Foreground="#0EA5E9" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Completed" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                        <TextBlock Name="AnalyticsCompletedText" FontSize="18" FontWeight="SemiBold" Foreground="#10B981" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Draft" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                        <TextBlock Name="AnalyticsDraftText" FontSize="18" FontWeight="SemiBold" Foreground="#F59E0B" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Voided" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                        <TextBlock Name="AnalyticsVoidedText" FontSize="18" FontWeight="SemiBold" Foreground="#EF4444" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Pcs" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                        <TextBlock Name="AnalyticsPcsText" FontSize="18" FontWeight="SemiBold" Foreground="#8B5CF6" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Total Qty" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                        <TextBlock Name="AnalyticsQtyText" FontSize="18" FontWeight="SemiBold" Foreground="#14B8A6" Text="0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Row: Top Operators + Load Distribution -->
                            <Grid Margin="0,16,0,0" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                    <StackPanel>
                                    <TextBlock Text="Top Operators" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                        <TextBlock Text="Loads, pieces, quantities (click a bar to drill down)" FontSize="10" Foreground="#6B7280" Margin="0,2,0,8"/>
                                        <lvc:CartesianChart Name="AnalyticsTopOperatorsChart" Height="250" ZoomMode="None" Background="Transparent"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Text="Load Distribution" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                        <TextBlock Name="AnalyticsLoadDistributionSubtitle" Text="Status breakdown (click a slice to drill down)" FontSize="10" Foreground="#6B7280" Margin="0,2,0,8"/>
                                        <lvc:PieChart Name="AnalyticsLoadDistributionPie" Height="250" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Top Sterilizers Performance -->
                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="Top Sterilizers Performance" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="Loads, pieces, quantities (click a bar to drill down)" FontSize="10" Foreground="#6B7280" Margin="0,2,0,8"/>
                                    <lvc:CartesianChart Name="AnalyticsTopSterilizersChart" Height="300" ZoomMode="None" Background="Transparent"/>
                                </StackPanel>
                            </Border>

                            <!-- Daily trend -->
                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="Daily activity" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="By calendar day — local (click a point to drill down for that day)" FontSize="10" Foreground="#6B7280" Margin="0,2,0,8"/>
                                    <lvc:CartesianChart Name="AnalyticsDailyTrendChart" Height="280" ZoomMode="None" Background="Transparent"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="BI trends (pass/fail/pending/missing)" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="Click a point to drill down for that day" FontSize="10" Foreground="#6B7280" Margin="0,2,0,8"/>
                                    <lvc:CartesianChart Name="AnalyticsBiTrendChart" Height="260" ZoomMode="None" Background="Transparent"/>
                                </StackPanel>
                            </Border>

                            <!-- Top operators snapshot (not time series) -->
                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="Top operators — quantity snapshot" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="Up to three operators by quantity — click a point to drill down" FontSize="10" Foreground="#6B7280" Margin="0,2,0,8"/>
                                    <lvc:CartesianChart Name="AnalyticsOperatorSnapshotChart" Height="220" ZoomMode="None" Background="Transparent"/>
                                </StackPanel>
                            </Border>

                            <!-- Breakdown drill-down -->
                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="Breakdown" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="Double-click a row, or click chart bars/points/slices, to open a drill-down window with exact structured filters." FontSize="10" Foreground="#6B7280" Margin="0,2,0,10"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="View" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#374151"/>
                                        <ComboBox Name="AnalyticsBreakdownCombo" Width="220" IsEditable="False" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DataGrid Name="AnalyticsBreakdownGrid" Height="220" AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                              SelectionMode="Single" IsReadOnly="True"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                </ScrollViewer>
                    <Button Name="NavExpandButton" Click="NavExpandButton_OnClick" Visibility="Collapsed"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,10,0,0" Panel.ZIndex="2"
                            Padding="10,12" FontSize="16" FontWeight="SemiBold" Content="⟩"
                            ToolTip="Show the sidebar menu again." Cursor="Hand"
                            Style="{StaticResource SecondaryToolbarButton}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E9ECEF" Padding="14,8" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
            <TextBlock Name="StatusText" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="#212529" FontSize="13" Text="Ready"/>
        </Border>
    </Grid>
</Window>
