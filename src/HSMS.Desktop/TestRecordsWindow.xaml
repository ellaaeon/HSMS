<UserControl x:Class="HSMS.Desktop.TestRecordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HSMS.Desktop.TestRecords.ViewModels"
        xmlns:mvvm="clr-namespace:HSMS.Desktop.Mvvm"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource SecondaryToolbarButton}"/>
        <mvvm:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <mvvm:BoolToVisibilityConverter x:Key="InverseBoolToVisibility" Invert="True"/>
        <Style x:Key="SideNavItem" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#BBD5FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F6F7FB"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="{StaticResource BrushCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Sterilization Test Records" FontSize="18" FontWeight="SemiBold" Foreground="#111827"/>
                    <TextBlock Text="Test records and workflows across all sterilization categories."
                               FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,4,0,0"/>
                </StackPanel>
                <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1: search + primary actions -->
                    <WrapPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,0,6">
                        <TextBox Width="240" Height="32" Margin="0,0,10,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding QuickSearch, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Quick search: cycle no, sterilizer, notes, technician"/>
                        <Button Content="Add" Style="{StaticResource SecondaryToolbarButton}" MinWidth="90"
                                Command="{Binding AddCommand}" Margin="0,0,10,0"/>
                        <Button Content="Refresh" Style="{StaticResource SecondaryToolbarButton}" MinWidth="100"
                                Command="{Binding RefreshCommand}" Margin="0,0,10,0"/>
                        <Button Name="CloseButton" Content="Close" Style="{StaticResource SecondaryToolbarButton}" MinWidth="95"
                                Margin="0,0,0,0" Visibility="Collapsed"/>
                    </WrapPanel>

                    <!-- Row 2: exports / print -->
                    <WrapPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Content="Export CSV" Style="{StaticResource SecondaryToolbarButton}" MinWidth="110"
                                Command="{Binding ExportCsvCommand}" Margin="0,0,10,0"/>
                        <Button Content="Export XLSX" Style="{StaticResource SecondaryToolbarButton}" MinWidth="115"
                                Command="{Binding ExportXlsxCommand}" Margin="0,0,10,0"/>
                        <Button Content="Export PDF" Style="{StaticResource SecondaryToolbarButton}" MinWidth="110"
                                Command="{Binding ExportTablePdfCommand}" Margin="0,0,10,0"/>
                        <Button Content="Print" Style="{StaticResource SecondaryToolbarButton}" MinWidth="90"
                                Command="{Binding PrintCommand}" Margin="0,0,0,0"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left navigation -->
            <Border Grid.Column="0" Background="{StaticResource BrushCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12" Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Test Records" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrushMuted}" Margin="6,2,6,10"/>
                        <ListBox Name="NavList" SelectedIndex="0" ItemContainerStyle="{StaticResource SideNavItem}" SelectionChanged="NavList_OnSelectionChanged">
                            <ListBoxItem Tag="Dashboard">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#1F3A8A"/>
                                    <TextBlock Grid.Column="1" Text="Dashboard" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="BowieDick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#0F766E"/>
                                    <TextBlock Grid.Column="1" Text="Bowie Dick" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="LeakTest">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#1D4ED8"/>
                                    <TextBlock Grid.Column="1" Text="Leak Test" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="WarmUpTest">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B45309"/>
                                    <TextBlock Grid.Column="1" Text="Warm Up Test" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="InstrumentTests">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#4338CA"/>
                                    <TextBlock Grid.Column="1" Text="Instrument Tests" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="Bi">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#BE123C"/>
                                    <TextBlock Grid.Column="1" Text="BI (Biological Indicator)" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="PPM">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#0E7490"/>
                                    <TextBlock Grid.Column="1" Text="PPM" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="Maintenance">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#374151"/>
                                    <TextBlock Grid.Column="1" Text="Maintenance / Calibration" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="Incidents">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#DC2626"/>
                                    <TextBlock Grid.Column="1" Text="Failed / Incidents" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                            <ListBoxItem Tag="Archive">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#6B7280"/>
                                    <TextBlock Grid.Column="1" Text="Archive" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                </Grid>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Main content -->
            <Border Grid.Column="2" Background="{StaticResource BrushCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Summary cards row (for non-dashboard workspaces) -->
                    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,2"
                                 Visibility="{Binding IsDashboardActive, Converter={StaticResource InverseBoolToVisibility}}">
                        <Border Background="#F8FAFD" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Total tests (range)" FontSize="11" Foreground="{StaticResource BrushMuted}"/>
                                <TextBlock Name="CardTotal" Text="—" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Approved / Passed" FontSize="11" Foreground="#065F46"/>
                                <TextBlock Name="CardApproved" Text="—" FontSize="18" FontWeight="SemiBold" Foreground="#065F46" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Failed" FontSize="11" Foreground="#991B1B"/>
                                <TextBlock Name="CardFailed" Text="—" FontSize="18" FontWeight="SemiBold" Foreground="#991B1B" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="10" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Pending review" FontSize="11" Foreground="#92400E"/>
                                <TextBlock Name="CardPending" Text="—" FontSize="18" FontWeight="SemiBold" Foreground="#92400E" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Dashboard workspace -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsDashboardActive, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <Border Background="#F8FAFD" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Dashboard Overview" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                                        <TextBlock Text="{Binding DashboardSummaryLine}" FontSize="11" Foreground="{StaticResource BrushMuted}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding IsDashboardLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=loading}"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <Border Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Category Breakdown" FontSize="12" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="Top categories" FontSize="11" Foreground="{StaticResource BrushMuted}" Margin="0,4,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Dashboard.ByCategory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6">
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Value}" FontWeight="SemiBold" Foreground="#111827"/>
                                                    <TextBlock Text="{Binding Key}" Foreground="{StaticResource BrushMuted}" TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Filters + grid (workspaces) -->
                    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="10"
                            Visibility="{Binding IsDashboardActive, Converter={StaticResource InverseBoolToVisibility}}">
                        <DockPanel>
                            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="From" Style="{StaticResource CaptionLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker Width="140" Margin="0,0,12,0" SelectedDate="{Binding FromLocal}"/>
                                <TextBlock Text="To" Style="{StaticResource CaptionLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker Width="140" Margin="0,0,12,0" SelectedDate="{Binding ToLocal}"/>
                                <TextBlock Text="Status" Style="{StaticResource CaptionLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox Width="150" Margin="0,0,12,0" SelectionChanged="StatusCombo_OnSelectionChanged">
                                    <ComboBoxItem Content="(all)" IsSelected="True"/>
                                    <ComboBoxItem Content="Draft"/>
                                    <ComboBoxItem Content="PendingReview"/>
                                    <ComboBoxItem Content="Approved"/>
                                    <ComboBoxItem Content="Failed"/>
                                    <ComboBoxItem Content="RetestRequired"/>
                                    <ComboBoxItem Content="Archived"/>
                                </ComboBox>
                                <CheckBox Content="Failed only" VerticalAlignment="Center" Margin="0,0,12,0" IsChecked="{Binding FailedOnly}"/>
                                <CheckBox Content="Pending only" VerticalAlignment="Center" Margin="0,0,12,0" IsChecked="{Binding PendingOnly}"/>
                                <CheckBox Content="Review queue" VerticalAlignment="Center" Margin="0,0,12,0" IsChecked="{Binding ReviewQueue}"
                                          ToolTip="Shows pending review items oldest-first (optimized for supervisors)."/>
                                <CheckBox Content="Group by sterilizer" VerticalAlignment="Center" Margin="0,0,12,0" IsChecked="{Binding GroupBySterilizer}"/>
                                <Button Content="Advanced…" Style="{StaticResource SecondaryToolbarButton}" MinWidth="110" Margin="0,0,12,0"
                                        Command="{Binding AdvancedFilterCommand}"/>
                            </WrapPanel>

                            <!-- Active filter chips -->
                            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <ItemsControl ItemsSource="{Binding ActiveFilterChips}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFD" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12" Padding="10,6" Margin="0,0,8,8">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#111827"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>

                            <Grid>
                                <!-- Load Records view (Instrument Tests workspace) -->
                                <DataGrid Name="LoadsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionUnit="FullRow"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      FontSize="12"
                                      HorizontalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding LoadsView}"
                                      SelectedItem="{Binding SelectedLoad, Mode=TwoWay}"
                                      Visibility="{Binding IsLoadRecordsView, Converter={StaticResource BoolToVisibility}}">
                                    <DataGrid.Resources>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding SterilizationId}" Width="70"/>
                                        <DataGridTextColumn Header="Cycle No" Binding="{Binding CycleNo}" Width="110"/>
                                        <DataGridTextColumn Header="Cycle Program" Binding="{Binding CycleProgram}" Width="140"/>
                                        <DataGridTextColumn Header="Sterilizer" Binding="{Binding SterilizerNo}" Width="120"/>
                                        <DataGridTextColumn Header="Operator" Binding="{Binding OperatorName}" Width="170"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding CycleStatus}" Width="120"/>
                                        <DataGridTextColumn Header="Registered (UTC)" Binding="{Binding RegisteredAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="170"/>
                                        <DataGridTextColumn Header="Pcs" Binding="{Binding TotalPcs}" Width="70"/>
                                        <DataGridTextColumn Header="Qty" Binding="{Binding TotalQty}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <DataGrid Name="RecordsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionUnit="FullRow"
                                      SelectionMode="Extended"
                                      HeadersVisibility="Column"
                                      FontSize="12"
                                      HorizontalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding RecordsView}"
                                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                                      Visibility="{Binding IsLoadRecordsView, Converter={StaticResource InverseBoolToVisibility}}">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="{x:Type GroupItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                            <Border Background="#F8FAFD" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,8">
                                                                <Expander IsExpanded="True" Background="Transparent">
                                                                <Expander.Header>
                                                                    <DockPanel Margin="10,8">
                                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ItemCount, StringFormat={}{0} items}" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#111827"/>
                                                                    </DockPanel>
                                                                </Expander.Header>
                                                                <ItemsPresenter/>
                                                                </Expander>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding RecordId}" Width="70"/>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140"/>
                                    <DataGridTextColumn Header="Cycle" Binding="{Binding CycleNo}" Width="100"/>
                                    <DataGridTextColumn Header="Sterilizer" Binding="{Binding SterilizerNo}" Width="110"/>
                                    <DataGridTextColumn Header="When (UTC)" Binding="{Binding TestDateTimeUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="145"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                    <DataGridTextColumn Header="Result" Binding="{Binding ResultLabel}" Width="85"/>
                                    <DataGridTextColumn Header="Technician" Binding="{Binding Technician}" Width="140"/>
                                    <DataGridTextColumn Header="Dept" Binding="{Binding Department}" Width="110"/>
                                    <DataGridCheckBoxColumn Header="Evidence" Binding="{Binding HasAttachments}" Width="75"/>
                                    <DataGridCheckBoxColumn Header="Legacy" Binding="{Binding IsLegacyQaTest}" Width="65"/>
                                    <!-- RowVersion is internal/debug; hiding prevents horizontal overflow -->
                                    <DataGridTextColumn Header="RowVersion" Binding="{Binding RowVersion}" Width="0" Visibility="Collapsed"/>
                                </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state (QA Test Records view) -->
                                <Border Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12"
                                        Padding="22" Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Style.Triggers>
                                                <!-- Show only when we're NOT in load-records view AND there are no QA records -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLoadRecordsView}" Value="False"/>
                                                        <Condition Binding="{Binding HasRecords}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                                        <TextBlock Text="No test records found" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextAlignment="Center"/>
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="This module shows test records. If your database has sterilization loads but no test records yet, the grid will be empty."
                                                   FontSize="12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                                        <TextBlock Margin="0,10,0,0"
                                                   Text="Try: widen the date range • clear Status filter • or click “New record” to create your first test record."
                                                   FontSize="12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Empty state (Load Records view) -->
                                <Border Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12"
                                        Padding="22" Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLoadRecordsView}" Value="True"/>
                                                        <Condition Binding="{Binding HasLoads}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                                        <TextBlock Text="No load records found" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextAlignment="Center"/>
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="This view lists sterilization loads for the selected category (Cycle Program). Try widening the date range or clear the search box."
                                                   FontSize="12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

