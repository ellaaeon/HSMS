<UserControl x:Class="HSMS.Desktop.Controls.BiPlusMinusSignToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="66"
             SnapsToDevicePixels="True"
             Focusable="False">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TextFg" Color="#0F172A"/>
        <SolidColorBrush x:Key="IdleBg" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="IdleBorder" Color="#CBD5E1"/>

        <Style x:Key="SignToggleBtnStyle" TargetType="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#0B1220"/>
            <Setter Property="Background" Value="{StaticResource IdleBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IdleBorder}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- One clean toggle button (click cycles + / - / blank). -->
    <Button x:Name="ToggleBtn"
            Style="{StaticResource SignToggleBtnStyle}"
            ToolTipService.ShowDuration="60000"
            ToolTipService.InitialShowDelay="250"
            Click="ToggleBtn_OnClick"
            PreviewKeyDown="Sign_OnPreviewKeyDown"
            >
        <Button.ToolTip>
            <ToolTip OverridesDefaultStyle="True"
                     Background="White" Foreground="#0F172A"
                     BorderBrush="#CBD5E1" BorderThickness="1"
                     Padding="8,6" Placement="Mouse" FontSize="12">
                <ToolTip.Template>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="Toggle + / − (Space toggles)"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </ToolTip.Template>
            </ToolTip>
        </Button.ToolTip>
    </Button>
        
</UserControl>

