<UserControl x:Class="HSMS.Desktop.Controls.BiPlusMinusNumericEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="34" d:DesignWidth="114"
             Focusable="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BiStepperBorder" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="BiStepperSurface" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BiStepperBtnIdle" Color="#EEF2F6"/>
        <SolidColorBrush x:Key="BiStepperBtnHover" Color="#E0E7FF"/>
        <SolidColorBrush x:Key="BiStepperBtnPressed" Color="#C7D2FE"/>
        <SolidColorBrush x:Key="BiStepperText" Color="#0F172A"/>

        <Style x:Key="BiStepRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="{StaticResource BiStepperText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Delay" Value="180"/>
            <Setter Property="Interval" Value="30"/>
            <Setter Property="Background" Value="{StaticResource BiStepperBtnIdle}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BiStepperBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BiStepperBtnPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BiStepperSurface}" BorderBrush="{StaticResource BiStepperBorder}"
            BorderThickness="1" CornerRadius="4" Padding="3" Margin="1,2"
            KeyboardNavigation.TabNavigation="Continue">
        <Grid>
            <Border Background="White" CornerRadius="3"
                    BorderBrush="#CBD5E1" BorderThickness="1" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="SignToggleButton" Grid.Column="0"
                            Focusable="False"
                            FontSize="12" FontWeight="SemiBold"
                            Foreground="{StaticResource BiStepperText}"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="Toggle sign (+ / -)"
                            Click="SignToggleButton_OnClick"/>

                    <TextBlock x:Name="PlaceholderZero" Grid.Column="1" Text="0"
                               FontSize="12" FontFamily="Segoe UI Semibold"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False" Visibility="Collapsed"/>

                    <TextBox x:Name="NumericText" Grid.Column="1"
                             FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"
                             Foreground="{StaticResource BiStepperText}"
                             Padding="0,5" MinHeight="30" MaxLength="4"
                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                             BorderThickness="0" Background="Transparent"
                             CaretBrush="#2563EB"
                             GotKeyboardFocus="NumericText_OnGotKeyboardFocus"
                             LostKeyboardFocus="NumericText_OnLostKeyboardFocus"
                             PreviewTextInput="NumericText_OnPreviewTextInput"
                             PreviewKeyDown="NumericText_OnPreviewKeyDown"
                             PreviewMouseLeftButtonDown="NumericText_OnPreviewMouseLeftButtonDown"
                             DataObject.Pasting="NumericText_OnPasting"
                             TextChanged="NumericText_OnTextChanged"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
