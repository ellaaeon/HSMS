<Window x:Class="HSMS.Desktop.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile"
        Height="640"
        Width="520"
        MinHeight="480"
        MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BrushSurface}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
        <Border Background="{StaticResource BrushCard}" CornerRadius="12"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                MaxWidth="460" Padding="24,22" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Profile" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrushPrimary}"/>
                <TextBlock Name="SubtitleText"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BrushMuted}"
                           FontSize="13"
                           LineHeight="18"
                           Margin="0,8,0,0"/>

                <Border Margin="0,18,0,0" Padding="14,12" Background="#F4F7FA" CornerRadius="8"
                        BorderBrush="#DEE6EE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Foreground="{StaticResource BrushMuted}" Text="Username"/>
                        <TextBlock Name="UsernameDisplay" Grid.Row="0" Grid.Column="1" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" Foreground="{StaticResource BrushMuted}" Text="Role"/>
                        <TextBlock Name="RoleDisplay" Grid.Row="2" Grid.Column="1" FontSize="13" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <TextBlock Text="Your details" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrushMuted}" Margin="0,20,0,0"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="First name *" Margin="0,12,0,0"/>
                <TextBox Name="FirstNameBox"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="Last name *" Margin="0,10,0,0"/>
                <TextBox Name="LastNameBox"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="Employee ID" Margin="0,10,0,0"/>
                <TextBox Name="EmployeeIdBox"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="Department" Margin="0,10,0,0"/>
                <TextBox Name="DepartmentBox"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="Job title" Margin="0,10,0,0"/>
                <TextBox Name="JobTitleBox"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="Email *" Margin="0,10,0,0"/>
                <TextBox Name="EmailBox"/>

                <TextBlock Style="{StaticResource CaptionLabel}" Text="Phone" Margin="0,10,0,0"/>
                <TextBox Name="PhoneBox"/>

                <TextBlock Name="ErrorText"
                           Margin="0,14,0,0"
                           Foreground="{StaticResource BrushDanger}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           FontSize="13"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Name="CancelButton" Content="Close" Style="{StaticResource SecondaryToolbarButton}" MinWidth="100" Margin="0,0,10,0" Click="CancelButton_OnClick"/>
                    <Button Name="SaveButton" Content="Save changes" Style="{StaticResource PrimaryButton}" MinWidth="130" Click="SaveButton_OnClick"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
