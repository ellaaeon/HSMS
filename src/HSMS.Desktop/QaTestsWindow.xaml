<Window x:Class="HSMS.Desktop.QaTestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QA Tests — Leak / Bowie-Dick"
        Height="640"
        Width="1080"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushSurface}"
        FontFamily="Segoe UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QA Tests" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource BrushPrimary}"/>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource CaptionLabel}" Text="Cycle no"/>
                        <TextBox Name="EntryCycleNoBox" ToolTip="Type the cycle number, then Tab to load the cycle."/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource CaptionLabel}" Text="Test type"/>
                        <ComboBox Name="EntryTestTypeCombo">
                            <ComboBoxItem Content="Leak"/>
                            <ComboBoxItem Content="BowieDick"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource CaptionLabel}" Text="Result"/>
                        <ComboBox Name="EntryResultCombo">
                            <ComboBoxItem Content="Pass"/>
                            <ComboBoxItem Content="Fail"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource CaptionLabel}" Text="Measured value"/>
                        <TextBox Name="EntryMeasuredBox" ToolTip="Optional, e.g. mbar/mins"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource CaptionLabel}" Text="Performed by"/>
                        <TextBox Name="EntryPerformedByBox"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource CaptionLabel}" Text="Notes"/>
                        <TextBox Name="EntryNotesBox" Height="56" AcceptsReturn="True" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                        <Button Name="SaveQaButton" Content="Save QA test" Style="{StaticResource SuccessToolbarButton}" MinWidth="130" Click="SaveQa_OnClick"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource CaptionLabel}" Text="From" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <DatePicker Name="FromDate" Width="140" Margin="0,0,12,0"/>
                    <TextBlock Style="{StaticResource CaptionLabel}" Text="To" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <DatePicker Name="ToDate" Width="140" Margin="0,0,12,0"/>
                    <TextBlock Style="{StaticResource CaptionLabel}" Text="Type" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox Name="FilterTypeCombo" Width="120" Margin="0,0,12,0">
                        <ComboBoxItem Content="(all)" IsSelected="True"/>
                        <ComboBoxItem Content="Leak"/>
                        <ComboBoxItem Content="BowieDick"/>
                    </ComboBox>
                    <CheckBox Name="PendingOnlyCheck" Content="Pending approval only" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Name="RefreshQaButton" Content="Refresh" Style="{StaticResource SecondaryToolbarButton}" MinWidth="95" Margin="0,0,8,0" Click="RefreshQa_OnClick"/>
                    <Button Name="ApproveButton" Content="Approve selected" Style="{StaticResource SecondaryToolbarButton}" MinWidth="140" Margin="0,0,8,0" Click="ApproveQa_OnClick"/>
                    <Button Name="PrintButton" Content="Print (F9)" Style="{StaticResource PrimaryButton}" MinWidth="120" Click="PrintQa_OnClick"/>
                </StackPanel>
                <DataGrid Name="QaGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionUnit="FullRow"
                          HeadersVisibility="Column" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding QaTestId}" Width="60"/>
                        <DataGridTextColumn Header="Cycle" Binding="{Binding CycleNo}" Width="100"/>
                        <DataGridTextColumn Header="Sterilizer" Binding="{Binding SterilizerNo}" Width="110"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding TestType}" Width="100"/>
                        <DataGridTextColumn Header="When (UTC)" Binding="{Binding TestDateTimeUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140"/>
                        <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="80"/>
                        <DataGridTextColumn Header="Value" Binding="{Binding MeasuredValue}" Width="80"/>
                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60"/>
                        <DataGridTextColumn Header="Performed by" Binding="{Binding PerformedBy}" Width="140"/>
                        <DataGridTextColumn Header="Approved by" Binding="{Binding ApprovedByUsername}" Width="120"/>
                        <DataGridTextColumn Header="Approved (UTC)" Binding="{Binding ApprovedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140"/>
                        <DataGridTextColumn Header="Approval remarks" Binding="{Binding ApprovedRemarks}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Style="{StaticResource SecondaryToolbarButton}" MinWidth="95" Click="Close_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
